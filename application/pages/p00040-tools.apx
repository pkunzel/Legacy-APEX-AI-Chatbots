page 40 (
    name: Tools
    alias: TOOLS
    title: Tools
    pageGroup: @administration
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText: Review chatbot-owned tool definitions. Tools are read-only execution contracts exposed to the model by BOT_TOOL_RUNNER.
    }

    region tools-report (
        name: Tools
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select t.id,
                       t.chatbot_id,
                       b.name as chatbot_name,
                       t.tool_name,
                       dbms_lob.substr(t.description, 4000, 1) as description,
                       t.tool_type,
                       t.enabled_yn,
                       t.max_rows,
                       t.max_result_chars,
                       t.created
                  from cb_tools t
                  join cb_chatbots b
                    on b.id = t.chatbot_id
                ```
        }
        layout {
            sequence: 20
            slot: BODY
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: tools_report
        }
        link {
            linkColumn: customTarget
            target: {
                page: 41
                items: {
                    P41_ID: #ID#
                }
                clearCache: 41
            }
            linkIcon: <span role="img" aria-label="Edit" class="fa fa-edit" title="Edit"></span>
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 100000
        }
        messages {
            whenNoDataFound: No tools found.
            whenMoreDataFound: This query returns more than #MAX_ROW_COUNT# rows, please filter your data to ensure complete results.
        }
        actionsMenu {
            savePublicReport: true
        }
        download {
            formats: [
                csv
                html
            ]
        }

        column ID (
            type: hidden
            heading {
                heading: ID
            }
            layout {
                sequence: 10
            }
            source {
                dataType: NUMBER
            }
        )

        column CHATBOT_ID (
            type: hidden
            heading {
                heading: Chatbot ID
            }
            layout {
                sequence: 20
            }
            source {
                dataType: NUMBER
            }
        )

        column CHATBOT_NAME (
            type: plainText
            heading {
                heading: Chatbot
            }
            layout {
                sequence: 30
            }
            source {
                dataType: STRING
            }
            comments {
                comments: Summary: Chatbot that owns this tool row. Display Label: Chatbot. Display in Report: true. Display in Form: true. Format Mask: none. Value Required: true. Read Only: false. Primary Display Column: true. Authorization Scheme: none.
            }
        )

        column TOOL_NAME (
            type: plainText
            heading {
                heading: Tool Name
            }
            layout {
                sequence: 40
            }
            source {
                dataType: STRING
            }
            comments {
                comments: Summary: Stable tool name exposed to the LLM within this chatbot. Display Label: Tool Name. Display in Report: true. Display in Form: true. Format Mask: none. Value Required: true. Read Only: false. Primary Display Column: false. Authorization Scheme: none.
            }
        )

        column DESCRIPTION (
            type: plainText
            heading {
                heading: Description
            }
            layout {
                sequence: 50
            }
            source {
                dataType: STRING
            }
            comments {
                comments: Summary: LLM-facing description of when and how to use the tool. Display Label: Description. Display in Report: true. Display in Form: true. Format Mask: none. Value Required: true. Read Only: false. Primary Display Column: false. Authorization Scheme: none.
            }
        )

        column TOOL_TYPE (
            type: plainText
            heading {
                heading: Tool Type
            }
            layout {
                sequence: 60
            }
            source {
                dataType: STRING
            }
            comments {
                comments: Summary: Internal tool executor type used by BOT_TOOL_RUNNER. Display Label: Tool Type. Display in Report: true. Display in Form: true. Format Mask: none. Value Required: true. Read Only: false. Primary Display Column: false. Authorization Scheme: none.
            }
        )

        column ENABLED_YN (
            type: plainText
            heading {
                heading: Enabled
            }
            layout {
                sequence: 70
            }
            source {
                dataType: STRING
            }
            comments {
                comments: Summary: Indicates whether this tool is currently exposed to the chatbot. Display Label: Enabled. Display in Report: true. Display in Form: true. Format Mask: none. Value Required: true. Read Only: false. Primary Display Column: false. Authorization Scheme: none.
            }
        )

        column MAX_ROWS (
            type: plainText
            heading {
                heading: Max Rows
                alignment: end
            }
            layout {
                sequence: 80
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G990
            }
            source {
                dataType: NUMBER
            }
            comments {
                comments: Summary: Maximum rows the tool may inspect or return. Display Label: Max Rows. Display in Report: true. Display in Form: true. Format Mask: 999G999G999G999G990. Value Required: true. Read Only: false. Primary Display Column: false. Authorization Scheme: none.
            }
        )

        column MAX_RESULT_CHARS (
            type: plainText
            heading {
                heading: Max Result Chars
                alignment: end
            }
            layout {
                sequence: 90
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G990
            }
            source {
                dataType: NUMBER
            }
            comments {
                comments: Summary: Maximum character count returned before clipping. Display Label: Max Result Chars. Display in Report: true. Display in Form: true. Format Mask: 999G999G999G999G990. Value Required: true. Read Only: false. Primary Display Column: false. Authorization Scheme: none.
            }
        )

        column CREATED (
            type: plainText
            heading {
                heading: Created
            }
            layout {
                sequence: 100
            }
            appearance {
                formatMask: DS
            }
            source {
                dataType: DATE
            }
            comments {
                comments: Summary: Date when the tool definition was created. Display Label: Created. Display in Report: true. Display in Form: true. Format Mask: DS. Value Required: true. Read Only: true. Primary Display Column: false. Authorization Scheme: none.
            }
        )

    )

    region breadcrumbs (
        name: Tools
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 40
            slot: REGION_POSITION_01
        }
        appearance {
            template: @/title-bar
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    button create-tool (
        buttonName: CREATE_TOOL
        label: Create Tool
        layout {
            sequence: 10
            region: @tools-report
            slot: RIGHT_OF_IR_SEARCH_BAR
        }
        appearance {
            buttonTemplate: @/text-with-icon
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-plus
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 41
                clearCache: 41
                request: CREATE
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction refresh-tools-after-dialog (
        name: Refresh Tools after Dialog
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @tools-report
        }

        action refresh-tools-report (
            action: refresh
            affectedElements {
                selectionType: region
                region: @tools-report
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)
