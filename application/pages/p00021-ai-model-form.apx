page 21 (
    name: AI Model Form
    alias: AI-MODEL-FORM
    title: AI Model
    pageGroup: @administration
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/drawer
        templateOptions: [
            #DEFAULT#
            js-dialog-class-t-Drawer--pullOutEnd
        ]
    }
    dialog {
        chained: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText: Create or update a model connection row. API keys are stored in the application table for this proof of concept.
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 20
            slot: REGION_POSITION_03
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region form (
        name: AI Model
        type: form
        source {
            location: localDatabase
            tableName: CB_AI_MODELS
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
        }
    )

    pageItem P21_ID (
        type: hidden
        layout {
            sequence: 10
            region: @form
            slot: regionBody
        }
        source {
            formRegion: @form
            column: ID
            dataType: number
            queryOnly: true
            primaryKey: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P21_NAME (
        type: textField
        label {
            label: Name
            alignment: left
        }
        layout {
            sequence: 20
            region: @form
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 40
        }
        validation {
            valueRequired: true
            maxLength: 150
        }
        source {
            formRegion: @form
            column: NAME
            dataType: varchar2
        }
        help {
            inlineHelpText: Display name
            helpText: Enter a unique name that administrators can recognize when selecting a model configuration.
        }
    )

    pageItem P21_SIGNATURE_TYPE (
        type: selectList
        label {
            label: Signature Type
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC:OpenAI Compatible;OPENAI_COMPATIBLE,Anthropic;ANTHROPIC,Claude;CLAUDE
            displayNullValue: false
        }
        layout {
            sequence: 40
            region: @form
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @form
            column: SIGNATURE_TYPE
            dataType: varchar2
        }
        help {
            inlineHelpText: Provider routing family
            helpText: Select the provider signature that CB_AGENT uses to choose the correct adapter implementation.
        }
    )

    pageItem P21_URL (
        type: textField
        label {
            label: URL
            alignment: left
        }
        layout {
            sequence: 50
            region: @form
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 80
        }
        validation {
            valueRequired: true
            maxLength: 4000
        }
        source {
            formRegion: @form
            column: URL
            dataType: varchar2
        }
        help {
            inlineHelpText: Provider endpoint
            helpText: Enter the HTTP endpoint that the selected adapter will call for this model configuration.
        }
    )

    pageItem P21_API_KEY (
        type: textField
        label {
            label: API Key
            alignment: left
        }
        layout {
            sequence: 60
            region: @form
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 80
        }
        validation {
            valueRequired: true
            maxLength: 4000
        }
        source {
            formRegion: @form
            column: API_KEY
            dataType: varchar2
        }
        help {
            inlineHelpText: Raw provider secret
            helpText: Store the raw provider API key. The adapter package formats provider-specific authorization headers at runtime.
        }
    )

    pageItem P21_MODEL (
        type: textField
        label {
            label: Model
            alignment: left
        }
        layout {
            sequence: 70
            region: @form
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 40
        }
        validation {
            valueRequired: true
            maxLength: 150
        }
        source {
            formRegion: @form
            column: MODEL
            dataType: varchar2
        }
        help {
            inlineHelpText: Provider model ID
            helpText: Enter the model identifier expected by the provider endpoint.
        }
    )

    pageItem P21_MAX_TOKENS (
        type: numberField
        label {
            label: Max Tokens
            alignment: left
        }
        layout {
            sequence: 80
            region: @form
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 20
        }
        source {
            formRegion: @form
            column: MAX_TOKENS
            dataType: number
        }
        help {
            inlineHelpText: Optional response limit
            helpText: Leave blank to let the package default apply, or enter a positive maximum response token value.
        }
    )

    pageItem P21_CREATED (
        type: displayOnly
        label {
            label: Created
            alignment: left
        }
        settings {
            sendOnPageSubmit: false
        }
        layout {
            sequence: 90
            region: @form
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @form
            column: CREATED
            dataType: date
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: CLOSE
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Create
        layout {
            sequence: 40
            region: @buttons
            slot: CREATE
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P21_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @buttons
            slot: DELETE
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
            requiresConfirmation: true
        }
        confirmation {
            message: Delete this AI model?
            style: danger
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P21_ID
        }
    )

    button apply-changes (
        buttonName: APPLY-CHANGES
        label: Apply Changes
        layout {
            sequence: 30
            region: @buttons
            slot: NEXT
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P21_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        execution {
            sequence: 50
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,APPLY-CHANGES,DELETE
        }
    )

    process initialize-form (
        name: Initialize AI Model Form
        type: formInitialization
        formRegion: @form
        execution {
            sequence: 10
            point: beforeHeader
        }
    )

    process process-form (
        name: Process AI Model Form
        type: formAutoRowProcessing
        formRegion: @form
        execution {
            sequence: 10
        }
    )

)
