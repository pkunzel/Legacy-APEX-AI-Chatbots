page 31 (
    name: Chatbot Conversation Form
    alias: CHATBOT-CONVERSATION-FORM
    title: Conversation Message
    pageGroup: @administration
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/drawer
        templateOptions: [
            #DEFAULT#
            js-dialog-class-t-Drawer--pullOutEnd
        ]
    }
    dialog {
        chained: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText: Create or update one conversation message. Message embeddings are maintained by the database trigger after message changes.
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 20
            slot: REGION_POSITION_03
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region form (
        name: Conversation Message
        type: form
        source {
            location: localDatabase
            tableName: CB_CHATBOT_CONVERSATIONS
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
        }
    )

    pageItem P31_ID (
        type: hidden
        layout {
            sequence: 10
            region: @form
            slot: regionBody
        }
        source {
            formRegion: @form
            column: ID
            dataType: number
            queryOnly: true
            primaryKey: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P31_CHATBOT_ID (
        type: selectList
        label {
            label: Chatbot
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select name,
                       id
                  from cb_chatbots
                 order by name
                ```
            displayNullValue: true
        }
        layout {
            sequence: 20
            region: @form
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @form
            column: CHATBOT_ID
            dataType: number
        }
        help {
            inlineHelpText: Owning chatbot
            helpText: Select the chatbot that owns this conversation message.
        }
    )

    pageItem P31_ROLE (
        type: selectList
        label {
            label: Role
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC:User;user,Assistant;assistant,System;system
            displayNullValue: false
        }
        layout {
            sequence: 40
            region: @form
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @form
            column: ROLE
            dataType: varchar2
        }
        help {
            inlineHelpText: Message speaker
            helpText: Choose whether this row represents a user, assistant, or system message.
        }
    )

    pageItem P31_MESSAGE (
        type: textarea
        label {
            label: Message
            alignment: left
        }
        layout {
            sequence: 50
            region: @form
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 80
            height: 8
        }
        validation {
            maxLength: 4000
        }
        source {
            formRegion: @form
            column: MESSAGE
            dataType: varchar2
        }
        help {
            inlineHelpText: Stored conversation text
            helpText: Enter the text that should be persisted for this conversation turn. Updating the text refreshes the message embedding through the trigger.
        }
    )

    pageItem P31_IS_SUMMARIZED (
        type: selectList
        label {
            label: Is Summarized
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC:No;N,Yes;Y
            displayNullValue: false
        }
        layout {
            sequence: 60
            region: @form
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @form
            column: IS_SUMMARIZED
            dataType: varchar2
        }
        help {
            inlineHelpText: Summary inclusion flag
            helpText: Set this to Yes only when the message has been included in the chatbot running summary.
        }
    )

    pageItem P31_SUMMARIZED_DATE (
        type: datePicker
        label {
            label: Summarized Date
            alignment: left
        }
        layout {
            sequence: 70
            region: @form
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
            width: 30
        }
        source {
            formRegion: @form
            column: SUMMARIZED_DATE
            dataType: date
        }
        help {
            inlineHelpText: Optional summary date
            helpText: Enter the date when this message was included in a summary, or leave blank for unsummarized rows.
        }
    )

    pageItem P31_CREATED (
        type: displayOnly
        label {
            label: Created
            alignment: left
        }
        settings {
            sendOnPageSubmit: false
        }
        layout {
            sequence: 80
            region: @form
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @form
            column: CREATED
            dataType: date
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: CLOSE
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Create
        layout {
            sequence: 40
            region: @buttons
            slot: CREATE
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P31_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @buttons
            slot: DELETE
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
            requiresConfirmation: true
        }
        confirmation {
            message: Delete this message?
            style: danger
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P31_ID
        }
    )

    button apply-changes (
        buttonName: APPLY-CHANGES
        label: Apply Changes
        layout {
            sequence: 30
            region: @buttons
            slot: NEXT
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P31_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        execution {
            sequence: 50
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,APPLY-CHANGES,DELETE
        }
    )

    process initialize-form (
        name: Initialize Conversation Form
        type: formInitialization
        formRegion: @form
        execution {
            sequence: 10
            point: beforeHeader
        }
    )

    process process-form (
        name: Process Conversation Form
        type: formAutoRowProcessing
        formRegion: @form
        execution {
            sequence: 10
        }
    )

)
