page 30 (
    name: Chatbot Conversations
    alias: CHATBOT-CONVERSATIONS
    title: Chatbot Conversations
    pageGroup: @administration
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText: Review stored chatbot conversation messages. The embedding column is maintained by the database trigger and is not edited manually.
    }

    region chatbot-conversations-report (
        name: Chatbot Conversations
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select c.id,
                       c.chatbot_id,
                       b.name as chatbot_name,
                       c.role,
                       c.message,
                       c.is_summarized,
                       c.summarized_date,
                       c.created
                  from cb_chatbot_conversations c
                  left join cb_chatbots b
                    on b.id = c.chatbot_id
                ```
        }
        layout {
            sequence: 20
            slot: BODY
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: chatbot_conversations_report
        }
        link {
            linkColumn: customTarget
            target: {
                page: 31
                items: {
                    P31_ID: #ID#
                }
                clearCache: 31
            }
            linkIcon: <span role="img" aria-label="Edit" class="fa fa-edit" title="Edit"></span>
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 100000
        }
        messages {
            whenNoDataFound: No conversation messages found.
            whenMoreDataFound: This query returns more than #MAX_ROW_COUNT# rows, please filter your data to ensure complete results.
        }
        actionsMenu {
            savePublicReport: true
        }
        download {
            formats: [
                csv
                html
            ]
        }

        column ID (
            type: hidden
            heading {
                heading: ID
            }
            layout {
                sequence: 10
            }
            source {
                dataType: NUMBER
            }
        )

        column CHATBOT_ID (
            type: hidden
            heading {
                heading: Chatbot ID
            }
            layout {
                sequence: 20
            }
            source {
                dataType: NUMBER
            }
        )

        column CHATBOT_NAME (
            type: plainText
            heading {
                heading: Chatbot
            }
            layout {
                sequence: 30
            }
            source {
                dataType: STRING
            }
            comments {
                comments: Summary: Display name of the chatbot that owns the message. Display Label: Chatbot. Display in Report: true. Display in Form: true. Format Mask: none. Value Required: false. Read Only: false. Primary Display Column: true. Authorization Scheme: none.
            }
        )

        column ROLE (
            type: plainText
            heading {
                heading: Role
            }
            layout {
                sequence: 40
            }
            source {
                dataType: STRING
            }
            comments {
                comments: Summary: Message participant role, such as user, assistant, or system. Display Label: Role. Display in Report: true. Display in Form: true. Format Mask: none. Value Required: true. Read Only: false. Primary Display Column: false. Authorization Scheme: none.
            }
        )

        column MESSAGE (
            type: plainText
            heading {
                heading: Message
            }
            layout {
                sequence: 50
            }
            source {
                dataType: STRING
            }
            comments {
                comments: Summary: Conversation message text stored for provider context and recall. Display Label: Message. Display in Report: true. Display in Form: true. Format Mask: none. Value Required: false. Read Only: false. Primary Display Column: false. Authorization Scheme: none.
            }
        )

        column IS_SUMMARIZED (
            type: plainText
            heading {
                heading: Is Summarized
            }
            layout {
                sequence: 60
            }
            source {
                dataType: STRING
            }
            comments {
                comments: Summary: Indicates whether this message has already been included in the running summary. Display Label: Is Summarized. Display in Report: true. Display in Form: true. Format Mask: none. Value Required: true. Read Only: false. Primary Display Column: false. Authorization Scheme: none.
            }
        )

        column SUMMARIZED_DATE (
            type: plainText
            heading {
                heading: Summarized Date
            }
            layout {
                sequence: 70
            }
            appearance {
                formatMask: DS
            }
            source {
                dataType: DATE
            }
            comments {
                comments: Summary: Date when the row was included in a summary operation. Display Label: Summarized Date. Display in Report: true. Display in Form: true. Format Mask: DS. Value Required: false. Read Only: false. Primary Display Column: false. Authorization Scheme: none.
            }
        )

        column CREATED (
            type: plainText
            heading {
                heading: Created
            }
            layout {
                sequence: 80
            }
            appearance {
                formatMask: DS
            }
            source {
                dataType: DATE
            }
            comments {
                comments: Summary: Date when the message was created. Display Label: Created. Display in Report: true. Display in Form: true. Format Mask: DS. Value Required: true. Read Only: true. Primary Display Column: false. Authorization Scheme: none.
            }
        )

    )

    region breadcrumbs (
        name: Chatbot Conversations
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 40
            slot: REGION_POSITION_01
        }
        appearance {
            template: @/title-bar
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    button create-conversation (
        buttonName: CREATE_CONVERSATION
        label: Create Message
        layout {
            sequence: 10
            region: @chatbot-conversations-report
            slot: RIGHT_OF_IR_SEARCH_BAR
        }
        appearance {
            buttonTemplate: @/text-with-icon
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-plus
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 31
                clearCache: 31
                request: CREATE
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction refresh-conversations-after-dialog (
        name: Refresh Conversations after Dialog
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @chatbot-conversations-report
        }

        action refresh-conversations-report (
            action: refresh
            affectedElements {
                selectionType: region
                region: @chatbot-conversations-report
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)
