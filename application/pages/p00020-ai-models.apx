page 20 (
    name: AI Models
    alias: AI-MODELS
    title: AI Models
    pageGroup: @administration
    appearance {
        pageTemplate: @/standard
        templateOptions: #DEFAULT#
    }
    navigation {
        cursorFocus: doNotFocusCursor
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText: Review model connection configurations used by CB_AGENT. API keys are edited in the drawer form and are not displayed in this report.
    }

    region ai-models-report (
        name: AI Models
        type: interactiveReport
        source {
            location: localDatabase
            type: sqlQuery
            sqlQuery:
                ```sql
                select id,
                       name,
                       signature_type,
                       url,
                       case when api_key is not null then 'Configured' else 'Missing' end as api_key_status,
                       model,
                       max_tokens,
                       created
                  from cb_ai_models
                ```
        }
        layout {
            sequence: 20
            slot: BODY
        }
        appearance {
            template: @/interactive-report
            templateOptions: #DEFAULT#
        }
        advanced {
            htmlDomId: ai_models_report
        }
        link {
            linkColumn: customTarget
            target: {
                page: 21
                items: {
                    P21_ID: #ID#
                }
                clearCache: 21
            }
            linkIcon: <span role="img" aria-label="Edit" class="fa fa-edit" title="Edit"></span>
        }
        componentAppearance {
            showNullValuesAs: -
        }
        pagination {
            type: rowRangesXToY
        }
        performance {
            maxRowsToProcess: 100000
        }
        messages {
            whenNoDataFound: No AI models found.
            whenMoreDataFound: This query returns more than #MAX_ROW_COUNT# rows, please filter your data to ensure complete results.
        }
        actionsMenu {
            savePublicReport: true
        }
        download {
            formats: [
                csv
                html
            ]
        }

        column ID (
            type: hidden
            heading {
                heading: ID
            }
            layout {
                sequence: 10
            }
            source {
                dataType: NUMBER
            }
        )

        column NAME (
            type: plainText
            heading {
                heading: Name
            }
            layout {
                sequence: 20
            }
            source {
                dataType: STRING
            }
            comments {
                comments: Summary: Display name used when selecting model configuration rows. Display Label: Name. Display in Report: true. Display in Form: true. Format Mask: none. Value Required: true. Read Only: false. Primary Display Column: true. Authorization Scheme: none.
            }
        )

        column SIGNATURE_TYPE (
            type: plainText
            heading {
                heading: Signature Type
            }
            layout {
                sequence: 30
            }
            source {
                dataType: STRING
            }
            comments {
                comments: Summary: Provider signature routed by CB_AGENT, such as OPENAI_COMPATIBLE or ANTHROPIC. Display Label: Signature Type. Display in Report: true. Display in Form: true. Format Mask: none. Value Required: true. Read Only: false. Primary Display Column: false. Authorization Scheme: none.
            }
        )

        column URL (
            type: plainText
            heading {
                heading: URL
            }
            layout {
                sequence: 40
            }
            source {
                dataType: STRING
            }
            comments {
                comments: Summary: Provider endpoint URL used by the adapter package. Display Label: URL. Display in Report: true. Display in Form: true. Format Mask: none. Value Required: true. Read Only: false. Primary Display Column: false. Authorization Scheme: none.
            }
        )

        column API_KEY_STATUS (
            type: plainText
            heading {
                heading: API Key
            }
            layout {
                sequence: 50
            }
            source {
                dataType: STRING
            }
            comments {
                comments: Summary: Indicates whether an API key has been saved without displaying the secret value. Display Label: API Key. Display in Report: true. Display in Form: false. Format Mask: none. Value Required: false. Read Only: true. Primary Display Column: false. Authorization Scheme: none.
            }
        )

        column MODEL (
            type: plainText
            heading {
                heading: Model
            }
            layout {
                sequence: 60
            }
            source {
                dataType: STRING
            }
            comments {
                comments: Summary: Provider model identifier passed to the adapter. Display Label: Model. Display in Report: true. Display in Form: true. Format Mask: none. Value Required: true. Read Only: false. Primary Display Column: false. Authorization Scheme: none.
            }
        )

        column MAX_TOKENS (
            type: plainText
            heading {
                heading: Max Tokens
                alignment: end
            }
            layout {
                sequence: 70
                columnAlignment: end
            }
            appearance {
                formatMask: 999G999G999G999G990
            }
            source {
                dataType: NUMBER
            }
            comments {
                comments: Summary: Optional default maximum token limit for responses. Display Label: Max Tokens. Display in Report: true. Display in Form: true. Format Mask: 999G999G999G999G990. Value Required: false. Read Only: false. Primary Display Column: false. Authorization Scheme: none.
            }
        )

        column CREATED (
            type: plainText
            heading {
                heading: Created
            }
            layout {
                sequence: 80
            }
            appearance {
                formatMask: DS
            }
            source {
                dataType: DATE
            }
            comments {
                comments: Summary: Date when the model configuration was created. Display Label: Created. Display in Report: true. Display in Form: true. Format Mask: DS. Value Required: true. Read Only: true. Primary Display Column: false. Authorization Scheme: none.
            }
        )

    )

    region breadcrumbs (
        name: AI Models
        type: breadcrumb
        source {
            breadcrumb: @breadcrumb
        }
        layout {
            sequence: 40
            slot: REGION_POSITION_01
        }
        appearance {
            template: @/title-bar
            templateOptions: #DEFAULT#
        }
        componentAppearance {
            breadcrumbTemplate: @/breadcrumb
            templateOptions: #DEFAULT#
        }
    )

    button create-ai-model (
        buttonName: CREATE_AI_MODEL
        label: Create AI Model
        layout {
            sequence: 10
            region: @ai-models-report
            slot: RIGHT_OF_IR_SEARCH_BAR
        }
        appearance {
            buttonTemplate: @/text-with-icon
            hot: true
            templateOptions: [
                #DEFAULT#
                t-Button--iconLeft
            ]
            icon: fa-plus
        }
        behavior {
            action: redirectThisApp
            target: {
                page: 21
                clearCache: 21
                request: CREATE
            }
            warnOnUnsavedChanges: doNotCheck
        }
    )

    dynamicAction refresh-ai-models-after-dialog (
        name: Refresh AI Models after Dialog
        execution {
            sequence: 10
        }
        when {
            event: apexafterclosedialog
            selectionType: region
            region: @ai-models-report
        }

        action refresh-ai-models-report (
            action: refresh
            affectedElements {
                selectionType: region
                region: @ai-models-report
            }
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

)
