page 41 (
    name: Tool Form
    alias: TOOL-FORM
    title: Tool
    pageGroup: @administration
    appearance {
        pageMode: modalDialog
        dialogTemplate: @/drawer
        templateOptions: [
            #DEFAULT#
            js-dialog-class-t-Drawer--pullOutEnd
        ]
    }
    dialog {
        chained: false
    }
    security {
        pageAccessProtection: argumentsMustHaveChecksum
        formAutoComplete: false
    }
    help {
        helpText: Create or update one chatbot-owned tool definition. Tool settings control what BOT_TOOL_RUNNER exposes to the model.
    }

    region buttons (
        name: Buttons
        type: staticContent
        layout {
            sequence: 20
            slot: REGION_POSITION_03
        }
        appearance {
            template: @/buttons-container
            templateOptions: #DEFAULT#
        }
        settings {
            outputAs: text
        }
    )

    region form (
        name: Tool
        type: form
        source {
            location: localDatabase
            tableName: CB_TOOLS
        }
        layout {
            sequence: 10
            slot: contentBody
        }
        appearance {
            template: @/blank-with-attributes
            templateOptions: #DEFAULT#
        }
        edit {
            enabled: true
        }
    )

    pageItem P41_ID (
        type: hidden
        layout {
            sequence: 10
            region: @form
            slot: regionBody
        }
        source {
            formRegion: @form
            column: ID
            dataType: number
            queryOnly: true
            primaryKey: true
        }
        security {
            sessionStateProtection: checksumRequiredSessionLevel
        }
    )

    pageItem P41_CHATBOT_ID (
        type: selectList
        label {
            label: Chatbot
            alignment: left
        }
        lov {
            type: sqlQuery
            sqlQuery:
                ```sql
                select name,
                       id
                  from cb_chatbots
                 order by name
                ```
            displayNullValue: false
        }
        layout {
            sequence: 20
            region: @form
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @form
            column: CHATBOT_ID
            dataType: number
        }
        help {
            inlineHelpText: Owning chatbot
            helpText: Select the chatbot that exposes this tool to the model.
        }
    )

    pageItem P41_TOOL_NAME (
        type: textField
        label {
            label: Tool Name
            alignment: left
        }
        layout {
            sequence: 40
            region: @form
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 40
        }
        validation {
            valueRequired: true
            maxLength: 150
        }
        source {
            formRegion: @form
            column: TOOL_NAME
            dataType: varchar2
        }
        help {
            inlineHelpText: Stable tool name
            helpText: Enter the tool name the model will request when it wants this capability.
        }
    )

    pageItem P41_DESCRIPTION (
        type: textarea
        label {
            label: Description
            alignment: left
        }
        layout {
            sequence: 50
            region: @form
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 80
            height: 6
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @form
            column: DESCRIPTION
            dataType: clob
        }
        help {
            inlineHelpText: LLM-facing usage guidance
            helpText: Describe when the model should use this tool and what the tool result means.
        }
    )

    pageItem P41_TOOL_TYPE (
        type: selectList
        label {
            label: Tool Type
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC:Conversation Memory;CONVERSATION_MEMORY
            displayNullValue: false
        }
        layout {
            sequence: 60
            region: @form
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @form
            column: TOOL_TYPE
            dataType: varchar2
        }
        help {
            inlineHelpText: Executor type
            helpText: Select the internal tool executor. Conversation Memory is the implemented tool type in this project.
        }
    )

    pageItem P41_ENABLED_YN (
        type: selectList
        label {
            label: Enabled
            alignment: left
        }
        lov {
            type: staticValues
            staticValues: STATIC:Yes;Y,No;N
            displayNullValue: false
        }
        layout {
            sequence: 70
            region: @form
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @form
            column: ENABLED_YN
            dataType: varchar2
        }
        help {
            inlineHelpText: Tool availability
            helpText: Choose whether this tool is currently exposed to the chatbot.
        }
    )

    pageItem P41_MAX_ROWS (
        type: numberField
        label {
            label: Max Rows
            alignment: left
        }
        layout {
            sequence: 80
            region: @form
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 20
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @form
            column: MAX_ROWS
            dataType: number
        }
        help {
            inlineHelpText: Positive row limit
            helpText: Enter the maximum number of rows or messages the tool may inspect or return.
        }
    )

    pageItem P41_MAX_RESULT_CHARS (
        type: numberField
        label {
            label: Max Result Chars
            alignment: left
        }
        layout {
            sequence: 90
            region: @form
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/required-floating
            templateOptions: #DEFAULT#
            width: 20
        }
        validation {
            valueRequired: true
        }
        source {
            formRegion: @form
            column: MAX_RESULT_CHARS
            dataType: number
        }
        help {
            inlineHelpText: Positive character limit
            helpText: Enter the maximum number of characters the tool may return before clipping.
        }
    )

    pageItem P41_CREATED (
        type: displayOnly
        label {
            label: Created
            alignment: left
        }
        settings {
            sendOnPageSubmit: false
        }
        layout {
            sequence: 100
            region: @form
            slot: regionBody
            alignment: left
        }
        appearance {
            template: @/optional-floating
            templateOptions: #DEFAULT#
        }
        source {
            formRegion: @form
            column: CREATED
            dataType: date
        }
    )

    button cancel (
        buttonName: CANCEL
        label: Cancel
        layout {
            sequence: 10
            region: @buttons
            slot: CLOSE
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            action: definedByDynamicAction
        }
    )

    button create (
        buttonName: CREATE
        label: Create
        layout {
            sequence: 40
            region: @buttons
            slot: CREATE
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: insert
        }
        serverSideCondition {
            type: itemIsNull
            item: P41_ID
        }
    )

    button delete (
        buttonName: DELETE
        label: Delete
        layout {
            sequence: 20
            region: @buttons
            slot: DELETE
        }
        appearance {
            buttonTemplate: @/text
            templateOptions: #DEFAULT#
        }
        behavior {
            executeValidations: false
            warnOnUnsavedChanges: doNotCheck
            databaseAction: delete
            requiresConfirmation: true
        }
        confirmation {
            message: Delete this tool?
            style: danger
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P41_ID
        }
    )

    button apply-changes (
        buttonName: APPLY-CHANGES
        label: Apply Changes
        layout {
            sequence: 30
            region: @buttons
            slot: NEXT
        }
        appearance {
            buttonTemplate: @/text
            hot: true
            templateOptions: #DEFAULT#
        }
        behavior {
            warnOnUnsavedChanges: doNotCheck
            databaseAction: update
        }
        serverSideCondition {
            type: itemIsNotNull
            item: P41_ID
        }
    )

    dynamicAction cancel-dialog (
        name: Cancel Dialog
        execution {
            sequence: 10
        }
        when {
            event: click
            selectionType: button
            button: @cancel
        }

        action native-dialog-cancel (
            action: cancelDialog
            execution {
                sequence: 10
                fireOnInit: false
            }
        )

    )

    process close-dialog (
        name: Close Dialog
        type: closeDialog
        execution {
            sequence: 50
        }
        serverSideCondition {
            type: requestIsContainedInValue
            value: CREATE,APPLY-CHANGES,DELETE
        }
    )

    process initialize-form (
        name: Initialize Tool Form
        type: formInitialization
        formRegion: @form
        execution {
            sequence: 10
            point: beforeHeader
        }
    )

    process process-form (
        name: Process Tool Form
        type: formAutoRowProcessing
        formRegion: @form
        execution {
            sequence: 10
        }
    )

)
